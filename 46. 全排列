from typing import List

class Solution:
    def permute(self, nums: List[int]) -> List[List[int]]:
        res = []
        used = [False] * len(nums)
        path = []

        #现在开始创造递归函数：
        def backtrack():
#==============================================================
            if len(path) == len(nums):
                res.append(path[:])#这里只能加入复制品,因为path在这里会被不断刷新！
                return 
#==============================================================
            for i in range(len(nums)):#这里直接写nums会直接报错！会出现越界的情况
                if used[i] == True:
                    continue
                
                used[i] = True     #标记一下这一个数字已经使用过！
                path.append(nums[i])
            
                backtrack()

                path.pop()#仔细理解一下，不会的去向Chat-GPT要完整的模拟流程！
                used[i] = False#我觉得这一句话特别关键，是换位置进行放置数字的关键！


        backtrack()
        return res
