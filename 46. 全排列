from typing import List

class Solution:
    def permute(self, nums: List[int]) -> List[List[int]]:
        res = []
        used = [False] * len(nums)#所有数字都还没被使用，所以必须 全部是 False
        path = []
        def backtrack():
#==============================================================
            # 如果路径长度等于 nums 长度，说明找到一个排列
            if len(path) == len(nums):
                res.append(path[:])  # 复制一份加入结果
                return#这个return是退出当前backtrack()的调用
    
#=================以上这一块就是函数输出的地方======================
            # 遍历所有数字，尝试选择一个没用过的
            for i in range(len(nums)):
                if used[i]:
                    continue  # 已经用过的跳过

                # 做选择
                used[i] = True
                path.append(nums[i])

                # 递归
                backtrack()#这是一个不需要输入任何参数的函数

                # 撤销选择（恢复现场）
                path.pop()
                used[i] = False

        backtrack()
        return res
