from typing import List
#这一题的关键是每个元素选与不选之间的一种判断！很关键！
class Solution:
    def subsets(self, nums: List[int]) -> List[List[int]]:
        
        res = []      # 存放所有子集
        path = []     # 当前正在构造的子集
        
        # start_index 表示：下一步从哪个位置开始选
        def backtrack(start_index):
            
            # ⭐子集问题：每到一个节点都要收集答案
            res.append(path[:])
            
            # 从 start_index 开始枚举选择
            for i in range(start_index, len(nums)):
                
                # 做选择
                path.append(nums[i])
                
                # 进入下一层（注意起点变成 i+1）
                backtrack(i + 1)
                
                # 撤销选择（回溯）
                path.pop()
        
        backtrack(0)
        return res
