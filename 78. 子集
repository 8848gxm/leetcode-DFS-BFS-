from typing import List

class Solution:
    def subsets(self, nums: List[int]) -> List[List[int]]:
        res = []
        path = []
        
        #开始创建回溯递归的函数
        def backtrack(start):
            res.append(path[:])

            for i in range(start,len(nums)):
                path.append(nums[i])

                backtrack(i + 1)
                #接下来就是还原
                path.pop()
        backtrack(0)
        return res
